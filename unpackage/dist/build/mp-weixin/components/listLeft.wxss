.listLeft{height:150px;margin-left:10px;color:#fff;width:150px}.author{height:35px;line-height:35px;font-size:15px}.title{width:100%;line-height:22px;font-size:12px;word-wrap:break-word}.music{height:35px;line-height:35px;font-size:12px;width:140px;-webkit-animation:music 4s linear .2s infinite;animation:music 4s linear .2s infinite}.box{width:100px;overflow:hidden}@-webkit-keyframes music{0%{-webkit-transform:translate3d(80%,0,0);transform:translate3d(80%,0,0)}100%{-webkit-transform:translate3d(-80%,0,0);transform:translate3d(-80%,0,0)}}@keyframes music{0%{-webkit-transform:translate3d(80%,0,0);transform:translate3d(80%,0,0)}100%{-webkit-transform:translate3d(-80%,0,0);transform:translate3d(-80%,0,0)}}