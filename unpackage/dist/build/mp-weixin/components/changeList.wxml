<view class="changeList"><scroll-view class="scrolly" scroll-y="true" scroll-into-view="{{viewId}}"><view class="city-false"><view class="box"><view class="title"><icon class="iconfont icon-dingwei"></icon>自动定位</view><view class="currentCity">{{tcity}}</view></view><view class="box"><view class="title">热门城市</view><view class="hotList"><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="item">{{''+item+''}}</view></block></view></view><block wx:for="{{city}}" wx:for-item="cities" wx:for-index="index" wx:key="index"><view class="box-list"><view class="initial" id="{{cities.initial}}">{{''+cities.initial+''}}</view><block wx:for="{{cities.list}}" wx:for-item="item" wx:for-index="__i0__" wx:key="code"><view data-event-opts="{{[['tap',[['click',['$0'],[[['city','',index],['list','code',item.code,'name']]]]]]]}}" class="cityName" bindtap="__e">{{''+item.name+''}}</view></block></view></block></view></scroll-view></view>